FROM nginx:1.25-alpine

# Valor padrão — pode ser sobrescrito em runtime via env var no Coolify.
# ENV garante que envsubst sempre encontra a variável, mesmo sem override.
ENV ADMIN_REDIRECT_URL=https://grafica.personalcreativemz.com/painel

COPY nginx-admin.conf.template /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
